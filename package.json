{
  "name": "rbx-tsx",
  "version": "0.1.0",
  "description": "TSX to Luau compiler targeting react-lua for Roblox",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "rbx-tsx": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external typescript",
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "generate": "bun run scripts/generate-types.ts"
  },
  "files": [
    "dist/",
    "types/",
    "README.md"
  ],
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "latest",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "typescript": "^5.8.3"
  }
}
